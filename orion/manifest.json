{
  "manifest_version": 3,
  "name": "EDH Power Level Exporter",
  "version": "1.6.0",
  "description": "Export Commander decks from Archidekt and Moxfield to EDH Power Level",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://moxfield.com/*",
    "https://edhpowerlevel.com/*",
    "https://archidekt.com/*",
    "https://api.moxfield.com/*",
    "https://www.archidekt.com/*",
    "https://api.archidekt.com/*",
    "https://www.moxfield.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "EDH Power Level Exporter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://archidekt.com/*",
        "https://www.archidekt.com/*",
        "https://moxfield.com/*",
        "https://www.moxfield.com/*"
      ],
      "js": ["content-deck-button.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://edhpowerlevel.com/*"],
      "js": ["content-edhpowerlevel.js"],
      "run_at": "document_start"
    }
  ]
}
